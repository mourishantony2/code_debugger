# MongoDB Atlas connection string
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/debug_event?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/debug_event?retryWrites=true&w=majority

# Flask secret key — change to a long random string in production
SECRET_KEY=change-me-to-a-long-random-string
